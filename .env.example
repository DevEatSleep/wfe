# Configuration Flask
FLASK_ENV=production
FLASK_APP=app.py
SECRET_KEY=your-secret-key-here-change-in-production

# Configuration Database (PostgreSQL)
# For local development: postgresql://username:password@localhost/financier
# For Render: Copy the DATABASE_URL from your Render PostgreSQL dashboard
DATABASE_URL=postgresql://localhost/financier

# Configuration Azure
PORT=8000
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=60

# Mode debug (à mettre à False en production)
DEBUG=False
